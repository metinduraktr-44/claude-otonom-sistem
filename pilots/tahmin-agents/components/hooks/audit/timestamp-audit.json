{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"{\\\"ts\\\":\\\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\\\",\\\"event\\\":\\\"edit\\\",\\\"files\\\":\\\"$CLAUDE_FILE_PATHS\\\"}\" >> AUDIT_LOG.jsonl"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python3 scripts/validate.py || true" }
        ]
      }
    ]
  }
}
