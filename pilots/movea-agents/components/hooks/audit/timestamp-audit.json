{
  "description": "Her Edit/Write sonrası gerçek UTC damgasını AUDIT_LOG.jsonl'a yazar; oturum sonunda stop olayını damgalar. Movéa damga+denetim protokolünün motoru.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"{\\\"ts\\\":\\\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\\\",\\\"event\\\":\\\"edit\\\",\\\"files\\\":\\\"$CLAUDE_FILE_PATHS\\\"}\" >> AUDIT_LOG.jsonl"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"{\\\"ts\\\":\\\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\\\",\\\"event\\\":\\\"stop\\\"}\" >> AUDIT_LOG.jsonl"
          }
        ]
      }
    ]
  }
}
